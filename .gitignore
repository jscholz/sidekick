# OS / editor
.DS_Store
Thumbs.db
*.swp
*~

# Runtime
node_modules/
*.log

# Client build output (regenerated by `npm run build`)
build/

# Per-user local env. The server reads DEEPGRAM_API_KEY, GW_TOKEN, and
# optional SIDEKICK_* overrides. Only .env.example is committed.
.env
.env.*
!.env.example

# Per-user Deepgram keyterm list — personal / project vocabulary. The
# committed template is keyterms.example.txt; copy to keyterms.txt and
# edit freely.
keyterms.txt

# Systemd EnvironmentFile= payloads — install to host, not repo.
config/systemd/*.env
!config/systemd/*.env.example
